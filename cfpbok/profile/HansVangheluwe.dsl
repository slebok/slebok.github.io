<li><span class="info">(<a href="../sle2010/index.html">SLE 2010</a>)</span> <em>Coauthored <a href="../sle2010/paper15.html">Debugging in Domain-Specific Modelling</a></em> (<a href="../profile/RaphaelMannadiar.html">Raphael Mannadiar</a>, <a href="../profile/HansVangheluwe.html"><span class="info">Hans Vangheluwe</span></a>) </li>
<li><span class="info">(<a href="../sle2014/index.html">SLE 2014</a>)</span> <em>Coauthored <a href="../sle2014/paper01.html">ProMoBox: A Framework for Generating Domain-Specific Property Languages</a></em> (<a href="../profile/BartMeyers.html">Bart Meyers</a>, <a href="../profile/RomualdDeshayes.html">Romuald Deshayes</a>, <a href="../profile/LucioLevi.html">Lucio Levi</a>, <a href="../profile/EugeneSyriani.html">Eugene Syriani</a>, <a href="../profile/HansVangheluwe.html"><span class="info">Hans Vangheluwe</span></a>, <a href="../profile/ManuelWimmer.html">Manuel Wimmer</a>) </li>
<li><span class="info">(<a href="../sle2014/index.html">SLE 2014</a>)</span> <em>Coauthored <a href="../sle2014/paper17.html">Dynamic Scope Discovery for Model Transformations</a></em> (<a href="../profile/MārisJukšs.html">Māris Jukšs</a>, <a href="../profile/ClarkVerbrugge.html">Clark Verbrugge</a>, <a href="../profile/DánielVarró.html">Dániel Varró</a>, <a href="../profile/HansVangheluwe.html"><span class="info">Hans Vangheluwe</span></a>) </li>
